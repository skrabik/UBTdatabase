# Скопируйте в .env и подставьте свои значения.
# Параметры для docker-compose.dev.yml:
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ubtdatabase
MYSQL_USER=ubt
MYSQL_PASSWORD=secret

# Dify Workflow API
DIFY_API_BASE_URL=https://dify-generator.ru/v1
DIFY_API_KEY=

# URL для отправки поста при создании (POST JSON с account-slug, login, password, article_title, article_text, headless)
POST_ARTICLE_URL=http://localhost:8000/post-article
HEADLESS=false
